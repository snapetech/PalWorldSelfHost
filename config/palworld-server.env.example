PALWORLD_INSTALL_DIR=/srv/palworld/server
PALWORLD_STEAMCMD=/usr/local/bin/steamcmd
PALWORLD_USER=palworld
PALWORLD_GROUP=palworld
PALWORLD_STATE_DIR=/var/lib/palworld
PALWORLD_BACKUP_LOCAL_ROOT=/var/backups/palworld
PALWORLD_RCLONE_DEST=remote:game-servers/palworld
RCLONE_CONFIG=/var/lib/palworld/.config/rclone/rclone.conf
PALWORLD_REQUIRE_LVM_BACKUP=false
PALWORLD_PUBLIC_DIR=/var/www/palworld
PALWORLD_EXPECTED_HOSTNAME=
PALWORLD_PORT=8211
PALWORLD_SERVER_NAME="Community Palworld - 50% XP, no drop on death"
PALWORLD_SERVER_DESCRIPTION="Live map and server status: https://example.com/palworld"
PALWORLD_PLAYER_EXP_RATE=0.5
PALWORLD_BACKUP_RETENTION_DAYS=14
PALWORLD_ADMIN_PASSWORD=generate-a-long-random-secret
PALWORLD_REST_PORT=8212
PALWORLD_OPS_BIND=127.0.0.1
PALWORLD_OPS_PORT=8213
PALWORLD_OPS_TOKEN=generate-a-separate-long-random-secret
PALWORLD_BACKUP_MAX_AGE_HOURS=26
PALWORLD_ALERT_COMMAND=
PALWORLD_WEBHOOK_URL=
PALWORLD_DISCORD_WEBHOOK_URL=
PALWORLD_NTFY_URL=
PALWORLD_GOTIFY_URL=
PALWORLD_MODERATION_ENABLED=false
PALWORLD_UPDATE_CHECK_MINUTES=30
PALWORLD_UPDATE_WARN_MINUTES=30
PALWORLD_UPDATE_MAX_DEFERRAL_HOURS=12
PALWORLD_MAINTENANCE_WAIT_SECONDS=300
PALWORLD_RESTART_WARN_SECONDS=60
PALWORLD_BACKUP_HOURLY_RETENTION_HOURS=48
PALWORLD_BACKUP_DAILY_RETENTION_DAYS=14
PALWORLD_BACKUP_WEEKLY_RETENTION_DAYS=90
PALWORLD_CRASH_LIMIT=5
PALWORLD_CRASH_WINDOW_MINUTES=15
PALWORLD_MATRIX_HOMESERVER=
PALWORLD_MATRIX_ACCESS_TOKEN=
PALWORLD_MATRIX_ROOMS=
